<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>


<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.desktop.system.sgli.sgli.Controller.WelcomeController"
      style="-fx-background-color: #1E90FF(to bottom, #667eea 0%, #764ba2 100%);
             -fx-padding: 40;
             -fx-min-width: 600;
             -fx-min-height: 500;">

    <!-- Título Principal -->
    <Text text="Seja Bem-Vindo"
          textAlignment="CENTER"
          style="-fx-font-size: 48px;
                 -fx-font-weight: bold;
                 -fx-font-family: 'Segoe UI';
                 -fx-fill: #FFFFFF;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 3, 0.5, 0, 2);">
        <VBox.margin>
            <Insets top="20" bottom="10"/>
        </VBox.margin>
    </Text>

<!--     Subtítulo -->
    <Text text="Seu Imobiliario"
          textAlignment="CENTER"
          style="-fx-font-size: 24px;
                 -fx-font-family: 'Segoe UI';
                 -fx-fill: #FFFFFF;
                 -fx-font-weight: bold;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 3, 0.5, 0, 2);
                 -fx-opacity: 0.9;">
        <VBox.margin>
            <Insets bottom="30"/>
        </VBox.margin>
    </Text>

    <!-- Botão Principal -->
    <Button
            onAction="#onClickToHub"
            text="Gerenciar"
            style="-fx-font-size: 18px;
                   -fx-font-weight: bold;
                   -fx-font-family: 'Segoe UI';
                   -fx-background-color: #3CB371;
                   -fx-text-fill: #FFFFFF;
                   -fx-background-radius: 25;
                   -fx-border-radius: 25;
                   -fx-padding: 15 30 15 30;
                   -fx-cursor: hand;
                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 2, 0.5, 0, 1);">
        <VBox.margin>
            <Insets bottom="40"/>
        </VBox.margin>

    </Button>


    <!-- Informações do Rodapé -->
    <VBox alignment="CENTER" spacing="5.0" style="-fx-opacity: 0.8;">
        <Text text="Hanspeter Dietiker | Copyright (c) 2026 "
              textAlignment="CENTER"
              style="-fx-font-size: 12px;
                     -fx-font-family: 'Segoe UI';
                     -fx-fill: #e9ecef;"/>
        <Text text="All rights reserved. "
              textAlignment="CENTER"
              style="-fx-font-size: 12px;
                     -fx-font-family: 'Segoe UI';
                     -fx-fill: #e9ecef;"/>
    </VBox>

</VBox>
